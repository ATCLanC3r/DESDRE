# Copy this file to .env. The defaults are suitable for a local Docker demo.
DJANGO_SECRET_KEY=replace-with-a-long-random-value-before-public-deployment
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DB_NAME=brfn_db
DB_USER=brfn_user
DB_PASSWORD=brfn_dev_password

# Demo records are created only when the database contains no products.
SEED_DEMO_DATA=true

# Payments must use Stripe test mode. Leave blank to use the local mock flow.
STRIPE_PUBLISHABLE_KEY=pk_test_51TsP4RCvjFAVAAttJ3PWHyxdnxvpWYeatboImKe8InunPJEFdZUunpqhqfRtyPi08o2TANNVbi02U3peMkUYJANW00GN7yrWsl
STRIPE_SECRET_KEY=sk_test_51TsP4RCvjFAVAAttSykYDT60YNSNnIyzJjsT7jgd5tqD7s00XXyBUchf5xwU1FR66mg1nCWJOMCElzAALRDWgu7F00EJOGg1mA
STRIPE_WEBHOOK_SECRET=

# Optional Backblaze B2 media storage. Local media storage is the default.
USE_B2_STORAGE=false
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_REGION=
DEV_NAME=local

# Set these only behind an HTTPS reverse proxy.
DJANGO_SECURE_COOKIES=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0